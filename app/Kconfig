choice BLINK
  prompt "BLINK choice"
  default BLINK_SLEEP_1000MS

config BLINK_SLEEP_250MS
    bool "Fast"
config BLINK_SLEEP_1000MS
    bool "Normal"
config BLINK_SLEEP_2000MS
    bool "Slow"
endchoice

config BLINK_SLEEP_TIME_MS 
    int 
    default 250 if BLINK_SLEEP_250MS
    default 1000 if BLINK_SLEEP_1000MS
    default 2000 if BLINK_SLEEP_2000MS
    default 0
    range 100 5000 
    help
          help  string can be multiline like this one


menuconfig LED_SUBSYSTEM
  bool "LED Subsystem"
  default y

  if LED_SUBSYSTEM 

  choice BLINK_SLEEP_TIME
    prompt "LED blink sleep time"
    default BLINK_SLEEP_TIME_1S

  config BLINK_SLEEP_TIME_250MS
      bool "250ms (very fast)"
  config BLINK_SLEEP_TIME_500MS
      bool "500ms  (fast)"
  config BLINK_SLEEP_TIME_1S
      bool "1s  (medium)"
  config BLINK_SLEEP_TIME_2S
      bool "2s (slow)"
  endchoice


menuconfig ADVANCED_LED_SETTINGS
  bool "Advanced LED settings"
  default y

if ADVANCED_LED_SETTINGS
config LED_BRIGHTNESS
  int "LED brightness (0-100)"
  range 0 100
  default 100

config LED_FADE_DURATION_MS
  int "LED fade duration (ms)"
  range 0 5000
  default 500

endif 

  menu "Expert settings"
    visible if ADVANCED_LED_SETTINGS

    config LED_DEBUGGING
      bool "Enable LED debugging"

    config CUSTOM_BLINK_PATTERN
      bool "Custom blink pattern"
  endmenu

endif

config BLINK_SLEEP_TIME_MS
  int
  default 250 if BLINK_SLEEP_TIME_250MS
  default 500 if BLINK_SLEEP_TIME_500MS
  default 1000 if BLINK_SLEEP_TIME_1S
  default 2000 if BLINK_SLEEP_TIME_2S


source "Kconfig.zephyr"

